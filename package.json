{
  "name": "raw-alchemy-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets": "node scripts/prepare-assets.mjs",
    "libraw-wasm": "bash scripts/build-libraw-wasm.sh",
    "wasm": "RUSTFLAGS='-C target-feature=+simd128' wasm-pack build crates/alchemy-core --target web --out-dir ../../web/src/wasm --release -- --features wasm && node scripts/check-wasm-boundaries.mjs",
    "predev": "npm run assets && npm run libraw-wasm && npm run wasm",
    "dev": "vite",
    "bundle": "tsc -b && vite build",
    "build": "npm run assets && npm run libraw-wasm && npm run wasm && npm run bundle",
    "build:pages": "VITE_BASE_PATH=/lut/ npm run build",
    "bundle:pages": "VITE_BASE_PATH=/lut/ vite build",
    "test": "vitest run",
    "test:e2e": "npm run build && npm run test:e2e:prepared",
    "test:e2e:prepared": "cargo build --quiet --release -p alchemy-cli && node scripts/check-libraw-parity.mjs && playwright test",
    "test:pages": "npm run build:pages && npm run test:pages:prepared",
    "test:pages:prepared": "VITE_BASE_PATH=/lut/ playwright test --config playwright.pages.config.ts",
    "benchmark:libraw": "npm run libraw-wasm && node scripts/benchmark-libraw-algorithms.mjs",
    "benchmark:browser": "RAW_PERF=1 PLAYWRIGHT_HTTP_PORT=${PLAYWRIGHT_HTTP_PORT:-46731} playwright test web/e2e/raw-performance.spec.ts --project=chromium",
    "benchmark:interaction": "RAW_PERF=1 PLAYWRIGHT_HTTP_PORT=${PLAYWRIGHT_HTTP_PORT:-46731} playwright test web/e2e/preview-interaction-performance.spec.ts --project=chromium",
    "quality:preview": "node scripts/check-preview-quality.mjs",
    "check": "npm run test && npm run build && cargo test --workspace && cargo clippy --workspace --all-targets -- -D warnings",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@radix-ui/react-select": "2.2.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fflate": "0.8.2",
    "lucide-react": "0.468.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "3.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.1.16",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-basic-ssl": "2.3.0",
    "@vitejs/plugin-react": "5.1.0",
    "jsdom": "27.1.0",
    "prettier": "3.6.2",
    "tailwindcss": "4.1.16",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
